# Base de données
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/washapp?schema=public"

# JWT
JWT_SECRET="CHANGE_ME_SUPER_SECRET_KEY_256_BITS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_KEY_256_BITS"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Firebase Admin (FCM push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Orange Money (Côte d'Ivoire)
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_MERCHANT_KEY=your-merchant-key
ORANGE_MONEY_AUTH_HEADER=your-base64-auth-header

# Cloudinary (stockage photos)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Upload local (si pas Cloudinary)
UPLOADS_PATH=./uploads

# Washer subscription
WASHER_SUBSCRIPTION_AMOUNT=35000
WASHER_SUBSCRIPTION_DURATION_DAYS=7

# Prix prestations (FCFA)
PRICE_EXTERIOR=1500
PRICE_INTERIOR=2500
PRICE_FULL=4000

# Dispatch
INSTANT_DISPATCH_TIMEOUT_SEC=20
BOOKING_DISPATCH_TIMEOUT_SEC=120
BOOKING_BLOCK_BEFORE_MINUTES=60

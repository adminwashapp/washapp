{
  "name": "washapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "web": "npm run dev --workspace=web",
    "api": "npm run start:dev --workspace=api",
    "build": "npm run build --workspace=web",
    "db:generate": "npm run prisma:generate --workspace=api",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "db:studio": "npm run prisma:studio --workspace=api"
  }
}